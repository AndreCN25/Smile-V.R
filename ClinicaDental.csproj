<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Evitar que este proyecto intente compilar los archivos del backend de las subcarpetas -->
    <DefaultItemExcludes>$(DefaultItemExcludes);Backend\**;bin\**;obj\**</DefaultItemExcludes>
  </PropertyGroup>

</Project>
